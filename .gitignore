# -----------------------------------------------
tfplan
*.tfplan

# -----------------------------------------------
# CRASH LOGS
# -----------------------------------------------
crash.log
crash.*.log

# -----------------------------------------------
# SENSITIVE VARIABLE FILES
# -----------------------------------------------
override.tf
override.tf.json
*_override.tf
*_override.tf.json
